@model ES2.DTOs.CriarAtividadeDto
@{
    ViewData["Title"] = "Criar Atividade";
    var categorias = ViewBag.Categorias as IEnumerable<ES2.Models.Categoria> 
                     ?? Enumerable.Empty<ES2.Models.Categoria>();
}

<div class="mt-4 mb-4">
    <h2 class="mb-1">Nova Atividade</h2>
    <p class="text-muted">Evento: <strong>@ViewBag.EventoNome</strong></p>
</div>

<div class="card shadow">
    <div class="card-body">
        <form asp-action="Criar" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="IdEvento" />

            <div class="mb-3">
                <label asp-for="Nome" class="form-label">Nome</label>
                <input asp-for="Nome" class="form-control" placeholder="Nome da atividade" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Local" class="form-label">Local</label>
                <input asp-for="Local" class="form-control" placeholder="Local da atividade" />
                <span asp-validation-for="Local" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Capacidade" class="form-label">Capacidade</label>
                <input asp-for="Capacidade" class="form-control" type="number" min="1" />
                <span asp-validation-for="Capacidade" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IdCategoria" class="form-label">Categoria</label>
                <select asp-for="IdCategoria" class="form-select">
                    <option value="">-- Seleciona uma categoria --</option>
                    @foreach (var cat in categorias)
                    {
                        <option value="@cat.IdCategoria">@cat.Nome</option>
                    }
                </select>
                <span asp-validation-for="IdCategoria" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Criar Atividade</button>
                <a asp-controller="Evento" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>