@model ES2.DTOs.CriarAtividadeDto

@{
    ViewData["Title"] = "Adicionar Atividade";
}

<h2>Adicionar Atividade ao Evento: @ViewBag.NomeEvento</h2>

<form asp-action="AdicionarAtividade" method="post">
    @Html.AntiForgeryToken()

    @* Campo escondido que guarda o ID do evento *@
    <input type="hidden" asp-for="IdEvento" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label">Nome da Atividade</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Local" class="form-label">Local</label>
        <input asp-for="Local" class="form-control" />
        <span asp-validation-for="Local" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Capacidade" class="form-label">Capacidade</label>
        <input asp-for="Capacidade" class="form-control" type="number" />
        <span asp-validation-for="Capacidade" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="IdCategoria" class="form-label">Categoria</label>
        @* Lista suspensa com as categorias existentes *@
        <select asp-for="IdCategoria" class="form-select"
                asp-items="@(new SelectList(ViewBag.Categorias, "IdCategoria", "Nome"))">
            <option value="">-- Seleciona uma categoria --</option>
        </select>
        <span asp-validation-for="IdCategoria" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Adicionar Atividade</button>
    <a href="javascript:history.back()" class="btn btn-secondary ms-2">Cancelar</a>
</form>