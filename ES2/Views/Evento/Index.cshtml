@model IEnumerable<ES2.Models.Evento>

@{
    ViewData["Title"] = "Eventos";
    var categorias = ViewBag.Categorias as IEnumerable<ES2.Models.Categoria> ?? Enumerable.Empty<ES2.Models.Categoria>();
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-4">
    <div>
        <h2 class="mb-1">Eventos</h2>
        <p class="text-light mb-0">Lista dos eventos ja criados no sistema.</p>
    </div>
    <div class="d-flex gap-2">
        <a id="btnEditarEvento" class="btn btn-primary disabled" aria-disabled="true">Editar Evento</a>
        <a asp-action="Criar" class="btn btn-success">Novo Evento</a>
    </div>
</div>

<div class="d-flex justify-content-start mb-3">
    <div class="btn-group btn-group-sm view-toggle" role="group" aria-label="Alternar visualizacao de eventos">
        <button type="button" class="btn btn-outline-light active" data-view-mode="tabela" title="Vista em lista">
            <i class="bi bi-list-ul"></i>
        </button>
        <button type="button" class="btn btn-outline-light" data-view-mode="catalogo" title="Vista em catalogo">
            <i class="bi bi-grid-3x3-gap"></i>
        </button>
    </div>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}

<div class="card shadow mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" id="formPesquisa" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Nome</label>
                <input type="text" name="nome" id="filtroNome" class="form-control" placeholder="Pesquisar por nome..." value="@ViewBag.FiltroNome" autocomplete="off" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Data</label>
                <input type="date" name="data" id="filtroData" class="form-control" value="@ViewBag.FiltroData" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Local</label>
                <input type="text" name="local" id="filtroLocal" class="form-control" placeholder="Pesquisar por local..." value="@ViewBag.FiltroLocal" autocomplete="off" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Categoria</label>
                <select name="idCategoria" id="filtroCategoria" class="form-select">
                    <option value="">Todas</option>
                    @foreach (var cat in categorias)
                    {
                        <option value="@cat.IdCategoria" selected="@(ViewBag.FiltroCategoria != null && (int)ViewBag.FiltroCategoria == cat.IdCategoria)">@cat.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Pesquisar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
            </div>
        </form>
    </div>
</div>

<div id="resultadoEventos">
    <partial name="_ResultadosEventos" model="Model" />
</div>

@section Scripts {
    <script>
        const resultadoEventos = document.getElementById('resultadoEventos');
        const btnEditarEvento = document.getElementById('btnEditarEvento');
        const botoesVista = document.querySelectorAll('.view-toggle [data-view-mode]');
        const inputs = ['filtroNome', 'filtroLocal'];
        const selects = ['filtroData', 'filtroCategoria'];
        const storageKey = 'eventos-view-mode';
        let debounce;
        let eventoSelecionadoId = null;

        function obterModoAtual() {
            return sessionStorage.getItem(storageKey) || 'tabela';
        }

        function atualizarBotoesVista(modo) {
            botoesVista.forEach(botao => {
                botao.classList.toggle('active', botao.dataset.viewMode === modo);
            });
        }

        function aplicarModoVisualizacao() {
            const modo = obterModoAtual();
            const tabela = document.getElementById('vistaTabelaEventos');
            const catalogo = document.getElementById('vistaCatalogoEventos');

            if (tabela && catalogo) {
                tabela.classList.toggle('d-none', modo !== 'tabela');
                catalogo.classList.toggle('d-none', modo !== 'catalogo');
            }

            atualizarBotoesVista(modo);
        }

        function atualizarBotaoEdicao() {
            if (eventoSelecionadoId) {
                btnEditarEvento.classList.remove('disabled');
                btnEditarEvento.removeAttribute('aria-disabled');
                btnEditarEvento.href = '@Url.Action("Editar", "Evento")/' + eventoSelecionadoId;
                return;
            }

            btnEditarEvento.classList.add('disabled');
            btnEditarEvento.setAttribute('aria-disabled', 'true');
            btnEditarEvento.removeAttribute('href');
        }

        function selecionarItem(item) {
            resultadoEventos.querySelectorAll('[data-evento-id]').forEach(elemento => elemento.classList.remove('evento-selecionado'));

            if (!item) {
                eventoSelecionadoId = null;
                atualizarBotaoEdicao();
                return;
            }

            item.classList.add('evento-selecionado');
            eventoSelecionadoId = item.dataset.eventoId;
            atualizarBotaoEdicao();
        }

        resultadoEventos.addEventListener('click', event => {
            const item = event.target.closest('[data-evento-id]');
            if (!item) {
                return;
            }

            if (eventoSelecionadoId === item.dataset.eventoId) {
                selecionarItem(null);
                return;
            }

            selecionarItem(item);
        });

        document.addEventListener('click', event => {
            if (!eventoSelecionadoId) {
                return;
            }

            if (event.target.closest('#resultadoEventos') || event.target.closest('#btnEditarEvento')) {
                return;
            }

            selecionarItem(null);
        });

        function pesquisar() {
            const params = new URLSearchParams({
                nome: document.getElementById('filtroNome').value,
                data: document.getElementById('filtroData').value,
                local: document.getElementById('filtroLocal').value,
                idCategoria: document.getElementById('filtroCategoria').value
            });

            fetch('@Url.Action("Pesquisar", "Evento")?' + params)
                .then(r => r.text())
                .then(html => {
                    resultadoEventos.innerHTML = html;
                    aplicarModoVisualizacao();

                    if (!eventoSelecionadoId) {
                        atualizarBotaoEdicao();
                        return;
                    }

                    const itemSelecionado = resultadoEventos.querySelector(`[data-evento-id="${eventoSelecionadoId}"]`);
                    selecionarItem(itemSelecionado);
                });
        }

        inputs.forEach(id => {
            document.getElementById(id).addEventListener('input', () => {
                clearTimeout(debounce);
                debounce = setTimeout(pesquisar, 300);
            });
        });

        selects.forEach(id => {
            document.getElementById(id).addEventListener('change', pesquisar);
        });

        botoesVista.forEach(botao => {
            botao.addEventListener('click', () => {
                sessionStorage.setItem(storageKey, botao.dataset.viewMode);
                aplicarModoVisualizacao();
            });
        });

        aplicarModoVisualizacao();
        atualizarBotaoEdicao();
    </script>

    <style>
        #resultadoEventos tr[data-evento-id],
        #resultadoEventos .catalogo-item[data-evento-id] {
            transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
            cursor: pointer;
        }

        #resultadoEventos tr.evento-selecionado td {
            background-color: rgba(13, 110, 253, 0.32) !important;
        }

        #resultadoEventos tr.evento-selecionado:hover td {
            background-color: rgba(13, 110, 253, 0.4) !important;
        }

        #resultadoEventos .catalogo-item {
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        #resultadoEventos .catalogo-item.evento-selecionado {
            background-color: rgba(13, 110, 253, 0.22);
            border-color: rgba(13, 110, 253, 0.75);
            transform: translateY(-5px); /* Efeito de "salto" */
            box-shadow: 0 0 25px 5px rgba(13, 110, 253, 0.6); /* Brilho azul */
        }
    </style>
}